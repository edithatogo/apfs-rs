{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":separateMajorReleases",
    ":enableVulnerabilityAlertsWithLabel(security)",
    ":maintainLockFilesWeekly",
    ":prHourlyLimitNone",
    ":prConcurrentLimit10"
  ],
  "enabledManagers": [
    "cargo",
    "github-actions",
    "npm",
    "dockerfile",
    "pip_requirements"
  ],
  "rangeStrategy": "bump",
  "rebaseWhen": "behind-base-branch",
  "labels": [
    "dependencies"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "cargo",
        "github-actions",
        "npm",
        "dockerfile",
        "pip_requirements"
      ],
      "minimumReleaseAge": "3 days"
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest"
      ],
      "automerge": false
    },
    {
      "matchPackageNames": [
        "jsonschema"
      ],
      "dependencyDashboardApproval": true,
      "prBodyNotes": [
        "APFS-RS policy gate: jsonschema major updates can introduce crypto/TLS transitive dependencies. Confirm issue #11 before merge."
      ]
    }
  ],
  "vulnerabilityAlerts": {
    "labels": [
      "security",
      "dependencies"
    ]
  }
}
